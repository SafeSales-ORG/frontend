# SafeSale frontend environment variables.
# Copy to `.env` and fill in. Never commit `.env`.

# Demo mode. When "true", the whole app runs on a reliable in-memory mock
# (no backend) and /admin is unlocked. Use this for demo-day recordings.
# Set to "false" (or remove) to use the real backend below.
VITE_DEMO_MODE=false

# Backend API base URL
VITE_API_URL=http://localhost:3000

# Google OAuth Client ID (required for "Continue with Google" sign-in on /onboarding).
# Create one at: https://console.cloud.google.com → APIs & Services → Credentials
#   → Create Credentials → OAuth 2.0 Client ID → Web application
# Add your local origin (http://localhost:8080) and production URL to
# "Authorized JavaScript origins". No redirect URI needed (implicit flow).
VITE_GOOGLE_CLIENT_ID=

# Nostr relays (comma-separated)
VITE_NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band,wss://relay.primal.net

# SafeSale service pubkeys (npub format). These are the authoritative authors
# the frontend trusts for kind 33888 (escrow service) and 33889 (mediator).
VITE_ESCROW_SERVICE_NPUB=
VITE_MEDIATOR_NPUB=

# Blossom servers for image uploads (comma-separated)
VITE_BLOSSOM_SERVERS=https://blossom.primal.net,https://nostr.build

# Public app URL (used in shared links, OG tags)
VITE_APP_URL=http://localhost:8080

# Transactional emails (order confirmation, shipped, delivered, completed,
# dispute, refund) are sent by the BACKEND via Resend — there is no
# frontend email config. The backend emails the buyer the order-tracking
# link once payment is confirmed by the Nomba webhook.

# Real support contacts shown in the Help dialog.
VITE_SUPPORT_EMAIL=
# WhatsApp number, digits only, international format (no +). e.g. 2348012345678
VITE_SUPPORT_WHATSAPP=
